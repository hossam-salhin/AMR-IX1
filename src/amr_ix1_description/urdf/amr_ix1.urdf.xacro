      </geometry>
    </collision>
  </link>

  <joint name="B_R_W_joint" type="continuous">
    <origin xyz="-0.444885 -0.528950 -0.259725" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="B_R_W_Link"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ================================================================
       BACK LEFT WHEEL
  ================================================================ -->
  <link name="B_L_W_Link">
    <inertial>
      <origin xyz="-0.000649 -0.055120 0.000395" rpy="0 0 0"/>
      <mass value="5.1478"/>
      <inertia
        ixx="0.035044" ixy="2.886E-11" ixz="7.307E-05"
        iyy="0.058291"  iyz="7.090E-11"
        izz="0.035109"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/B_L_W_Link.STL"/>
              <scale>0.001 0.001 0.001</scale>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/B_L_W_Link.STL"/>
              <scale>0.001 0.001 0.001</scale>
      </geometry>
    </collision>
  </link>

  <joint name="B_L_W_joint" type="continuous">
    <origin xyz="-0.446680 0.541050 -0.256487" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="B_L_W_Link"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ================================================================
       IMU
  ================================================================ -->
  <link name="imu_Link">
    <inertial>
      <origin xyz="-0.000400 0.000132 0.006812" rpy="0 0 0"/>
      <mass value="0.010837"/>
      <inertia
        ixx="9.951E-07" ixy="2.081E-08" ixz="1.091E-08"
        iyy="9.555E-07"  iyz="-3.252E-09"
