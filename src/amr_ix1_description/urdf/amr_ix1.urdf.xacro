<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="amr_ix1">

  <!-- ================================================================
       AMR-IX1 Inspection Robot — URDF/Xacro Description
       Maintainer: Hossam
