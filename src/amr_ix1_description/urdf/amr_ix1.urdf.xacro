  <!-- ── Materials ────────────────────────────────────────────────── -->
  <material name="dark_grey">
    <color rgba="0.251 0.251 0.251 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.753 0.753 0.753 1.0"/>
  </material>
  <material name="metal_grey">
    <color rgba="0.627 0.627 0.627 1.0"/>
  </material>
  <material name="dark_charcoal">
    <color rgba="0.212 0.212 0.204 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 0.984 0.984 1.0"/>
  </material>
  <material name="blue_grey">
    <color rgba="0.792 0.820 0.933 1.0"/>
  </material>

  <!-- ================================================================
       BASE FOOTPRINT — dummy root link (required by Nav2 and Gazebo)
  ================================================================ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.3347" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child  link="base_link"/>
  </joint>

  <!-- ================================================================
       BASE LINK
  ================================================================ -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.048088 0.015216 -0.117965" rpy="0 0 0"/>
      <mass value="17.7024"/>
      <inertia
        ixx="0.212987" ixy="-4.778E-07" ixz="0.014399"
        iyy="0.266448"  iyz="0.002175"
        izz="0.358088"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/base_link.STL"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ================================================================
       FRONT RIGHT WHEEL
  ================================================================ -->
  <link name="F_R_W_Link">
    <inertial>
      <origin xyz="0.000654 0.055120 0.000386" rpy="0 0 0"/>
      <mass value="5.1478"/>
      <inertia
        ixx="0.035042" ixy="2.794E-11" ixz="-7.220E-05"
        iyy="0.058291"  iyz="-7.127E-11"
        izz="0.035111"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/F_R_W_Link.STL"/>
              <scale>0.001 0.001 0.001</scale>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/F_R_W_Link.STL"/>
              <scale>0.001 0.001 0.001</scale>
      </geometry>
    </collision>
  </link>

  <joint name="F_R_W_joint" type="continuous">
    <origin xyz="0.273978 -0.529050 -0.259730" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="F_R_W_Link"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ================================================================
       FRONT LEFT WHEEL
  ================================================================ -->
  <link name="F_L_W_Link">
    <inertial>
      <origin xyz="5.723E-07 -0.055120 -0.000759" rpy="0 0 0"/>
      <mass value="5.1478"/>
      <inertia
        ixx="0.035156" ixy="-7.557E-11" ixz="-4.648E-06"
        iyy="0.058291"  iyz="-1.223E-11"
        izz="0.034997"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/F_L_W_Link.STL"/>
              <scale>0.001 0.001 0.001</scale>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
