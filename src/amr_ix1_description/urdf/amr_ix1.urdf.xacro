    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/imu_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0.000249 0.003020 -0.012600" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="imu_Link"/>
  </joint>

  <!-- ================================================================
       LIDAR
  ================================================================ -->
  <link name="laser_Link">
    <inertial>
      <origin xyz="-0.005720 0.001226 -0.009051" rpy="0 0 0"/>
      <mass value="0.141654"/>
      <inertia
        ixx="5.691E-05" ixy="-2.879E-07" ixz="-1.248E-05"
        iyy="8.932E-05"  iyz="7.219E-07"
        izz="1.087E-04"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/laser_Link.STL"/>
      </geometry>
      <material name="dark_charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/laser_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0.328135 -0.004554 0.047500" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="laser_Link"/>
  </joint>

  <!-- ================================================================
       CAMERA STAND
  ================================================================ -->
  <link name="cam_stand_Link">
    <inertial>
      <origin xyz="0.005597 0.032884 -0.000945" rpy="0 0 0"/>
      <mass value="0.008532"/>
      <inertia
        ixx="5.125E-06" ixy="-1.127E-07" ixz="2.108E-09"
        iyy="9.300E-07"  iyz="1.718E-08"
        izz="4.259E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/cam_stand_Link.STL"/>
      </geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/cam_stand_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="cam_stand_joint" type="revolute">
    <origin xyz="-0.274040 -0.063863 0.520470" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="cam_stand_Link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.7854" upper="0" effort="10.0" velocity="1.5" />
    <dynamics damping="0.1" friction="0.1"/>	
  </joint>

  <!-- ================================================================
       CAMERA
  ================================================================ -->
  <link name="camera_Link">
    <inertial>
      <origin xyz="-0.010605 -5.056E-05 -0.001198" rpy="0 0 0"/>
      <mass value="0.025772"/>
      <inertia
        ixx="6.271E-06" ixy="1.006E-11" ixz="3.897E-09"
        iyy="4.255E-06"  iyz="1.509E-10"
        izz="4.285E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/camera_Link.STL"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/camera_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.028695 0.053607 0.000157" rpy="0 0 0"/>
    <parent link="cam_stand_Link"/>
    <child  link="camera_Link"/>
  </joint>

  <!-- ================================================================
       THERMAL CAMERA
  ================================================================ -->
  <link name="thermal_link">
    <inertial>
      <origin xyz="-0.009412 0.000127 -0.000586" rpy="0 0 0"/>
      <mass value="0.024852"/>
      <inertia
        ixx="6.238E-06" ixy="1.086E-11" ixz="3.867E-09"
        iyy="4.239E-06"  iyz="-6.644E-11"
        izz="4.273E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/thermal_link.STL"/>
      </geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/collision/thermal_link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="thermal_joint" type="fixed">
    <origin xyz="0.027189 0.016420 -0.000526" rpy="0 0 0"/>
    <parent link="cam_stand_Link"/>
    <child  link="thermal_link"/>
  </joint>

</robot>
