  <joint name="F_L_W_joint" type="continuous">
    <origin xyz="0.272414 0.541050 -0.262472" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="F_L_W_Link"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ================================================================
       BACK RIGHT WHEEL
  ================================================================ -->
  <link name="B_R_W_Link">
    <inertial>
      <origin xyz="-9.003E-06 0.055120 -0.000759" rpy="0 0 0"/>
      <mass value="5.1478"/>
      <inertia
        ixx="0.035157" ixy="-7.543E-11" ixz="2.874E-06"
        iyy="0.058291"  iyz="1.306E-11"
        izz="0.034997"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_ix1_description/meshes/visual/B_R_W_Link.STL"/>
